# Configuration pour la version PAYANTE (avec tous les features)
# Copiez ce fichier vers .env.paid et remplissez les valeurs

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
VITE_GOOGLE_MAPS_EMBED_KEY=your_google_maps_key
VITE_MAPBOX_TOKEN=your_mapbox_token

VITE_FIREBASE_CUSTOM_TOKEN=
VITE_APP_ID=parkswap-paid

# ✅ ACTIVER LES PAIEMENTS
VITE_PAYMENT_ENABLED=true
VITE_SHOW_WALLET=true
VITE_SHOW_PRICES=true
